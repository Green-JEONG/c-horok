generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "horok_log", "horok_coding"]
}

enum Role {
  USER
  ADMIN

  @@schema("public")
}

enum AuthProvider {
  credentials
  github
  google

  @@schema("public")
}

enum ChatMessageRole {
  user
  assistant

  @@schema("public")
}

model User {
  id                    BigInt                @id @default(autoincrement())
  email                 String                @unique @db.VarChar(255)
  password              String?               @db.VarChar(255)
  name                  String?               @db.VarChar(100)
  image                 String?               @db.VarChar(512)
  oauthImage            String?               @map("oauth_image") @db.VarChar(512)
  role                  Role                  @default(USER)
  provider              AuthProvider
  snsId                 String?               @unique @map("sns_id") @db.VarChar(50)
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @default(now()) @updatedAt @map("updated_at")
  isBlocked             Boolean               @default(false) @map("is_blocked")
  blockedAt             DateTime?             @map("blocked_at")
  blockedReason         String?               @map("blocked_reason") @db.VarChar(255)

  chatHandoffs          ChatHandoff[]         @relation("ChatHandoffUser")
  chatHandoffReplies    ChatHandoff[]         @relation("ChatHandoffAdmin")
  chatMessages          ChatMessage[]         @relation("ChatMessageSender")
  chatThreads           ChatThread[]
  comments              Comment[]
  codingMember            CodingMember?
  codingProblemProgresses CodingProblemProgress[]
  codingSavedCodes        CodingSavedCode[]
  codingSubmissions       CodingSubmission[]
  followers             Friend[]              @relation("FriendFriendUser")
  friendships           Friend[]              @relation("FriendUser")
  notifications         Notification[]        @relation("NotificationActor")
  postLikes             PostLike[]
  posts                 Post[]
  receivedNotifications Notification[]        @relation("NotificationRecipient")
  logMember             LogMember?

  @@map("users")
  @@schema("public")
}

model ChatThread {
  id        BigInt         @id @default(autoincrement())
  userId    BigInt         @map("user_id")
  title     String?        @db.VarChar(120)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  handoffs  ChatHandoff[]
  messages  ChatMessage[]
  notifications Notification[]

  @@index([userId, updatedAt], map: "idx_chat_threads_user_updated_at")
  @@map("chat_threads")
  @@schema("public")
}

model ChatMessage {
  id        BigInt          @id @default(autoincrement())
  threadId  BigInt          @map("thread_id")
  senderUserId BigInt?      @map("sender_user_id")
  role      ChatMessageRole
  content   String          @db.Text
  createdAt DateTime        @default(now()) @map("created_at")

  thread    ChatThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User?           @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([senderUserId], map: "idx_chat_messages_sender_user_id")
  @@index([threadId, createdAt], map: "idx_chat_messages_thread_created_at")
  @@map("chat_messages")
  @@schema("public")
}

model ChatHandoff {
  id              BigInt     @id @default(autoincrement())
  threadId        BigInt     @map("thread_id")
  userId          BigInt     @map("user_id")
  status          String     @default("pending") @db.VarChar(20)
  reason          String?    @db.Text
  adminReply      String?    @map("admin_reply") @db.Text
  repliedByUserId BigInt?    @map("replied_by_user_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  repliedAt       DateTime?  @map("replied_at")

  thread          ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user            User       @relation("ChatHandoffUser", fields: [userId], references: [id], onDelete: Cascade)
  repliedBy       User?      @relation("ChatHandoffAdmin", fields: [repliedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt], map: "idx_chat_handoffs_status_created_at")
  @@index([userId, createdAt], map: "idx_chat_handoffs_user_created_at")
  @@map("chat_handoffs")
  @@schema("public")
}

model Category {
  id        BigInt    @id @default(autoincrement())
  name      String    @db.VarChar(50)
  slug      String    @unique @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  posts     Post[]
  postCategories PostCategory[]

  @@map("categories")
  @@schema("horok_log")
}

model Post {
  id            BigInt          @id @default(autoincrement())
  userId        BigInt          @map("user_id")
  categoryId    BigInt?         @map("category_id")
  title         String          @db.VarChar(200)
  content       String          @db.Text
  thumbnail     String?         @db.VarChar(255)
  thumbnailCrop  Json?           @map("thumbnail_crop")
  isBanner      Boolean         @default(false) @map("is_banner")
  isResolved    Boolean         @default(false) @map("is_resolved")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")
  isHidden      Boolean         @default(false) @map("is_hidden")
  isSecret      Boolean         @default(false) @map("is_secret")
  secretPasswordHash String?    @map("secret_password_hash") @db.VarChar(255)
  quotedPostId  BigInt?         @map("quoted_post_id")
  hiddenAt      DateTime?       @map("hidden_at")
  isDeleted     Boolean         @default(false) @map("is_deleted")
  deletedAt     DateTime?       @map("deleted_at")
  deletedBy     Int?            @map("deleted_by")

  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  comments      Comment[]
  likes         PostLike[]
  postCategories PostCategory[]
  quotedPost    Post?           @relation("PostQuotes", fields: [quotedPostId], references: [id], onDelete: SetNull)
  quotingPosts  Post[]          @relation("PostQuotes")
  downloadCounts PostDownloadCount?
  attachments   PostAttachment[]
  views         PostView?
  notifications Notification[]
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "idx_posts_created_at")
  @@index([quotedPostId], map: "idx_posts_quoted_post_id")
  @@map("posts")
  @@schema("horok_log")
}

model PostDownloadCount {
  postId        BigInt   @id @map("post_id")
  markdownCount Int      @default(0) @map("markdown_count")
  pdfCount      Int      @default(0) @map("pdf_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_download_counts")
  @@schema("horok_log")
}

model PostAttachment {
  id        BigInt   @id @default(autoincrement())
  postId    BigInt   @map("post_id")
  fileName  String   @map("file_name") @db.VarChar(255)
  fileUrl   String   @map("file_url") @db.VarChar(500)
  fileSize  Int?     @map("file_size")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId], map: "idx_post_attachments_post_id")
  @@map("post_attachments")
  @@schema("horok_log")
}

model PostCategory {
  postId     BigInt   @map("post_id")
  categoryId BigInt   @map("category_id")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@id([postId, categoryId])
  @@index([categoryId], map: "idx_post_categories_category_id")
  @@map("post_categories")
  @@schema("horok_log")
}

model Comment {
  id            BigInt          @id @default(autoincrement())
  postId        BigInt          @map("post_id")
  userId        BigInt          @map("user_id")
  parentId      BigInt?         @map("parent_id")
  content       String          @db.Text
  isDeleted     Boolean         @default(false) @map("is_deleted")
  isHidden      Boolean         @default(false) @map("is_hidden")
  isSecret      Boolean         @default(false) @map("is_secret")
  hiddenAt      DateTime?       @map("hidden_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @updatedAt @map("updated_at")

  notifications Notification[]
  parent        Comment?        @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  post          Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  replies       Comment[]       @relation("CommentReplies")
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([parentId], map: "fk_comments_parent")
  @@index([postId], map: "fk_comments_post")
  @@index([userId], map: "fk_comments_user")
  @@map("comments")
  @@schema("horok_log")
}

model PostLike {
  postId    BigInt   @map("post_id")
  userId    BigInt   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId], map: "fk_likes_user")
  @@map("post_likes")
  @@schema("horok_log")
}

model PostView {
  postId     BigInt   @id @map("post_id")
  viewCount  BigInt   @default(0) @map("view_count")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_views")
  @@schema("horok_log")
}

model StopWord {
  word String @id @db.VarChar(50)

  @@map("stop_words")
  @@schema("horok_log")
}

model Friend {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  friendUserId BigInt   @map("friend_user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  
  user         User     @relation("FriendUser", fields: [userId], references: [id], onDelete: Cascade)
  friendUser   User     @relation("FriendFriendUser", fields: [friendUserId], references: [id], onDelete: Cascade)

  @@unique([userId, friendUserId])
  @@index([friendUserId])
  @@map("friends")
  @@schema("public")
}

model Notification {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  actorId   BigInt?   @map("actor_id")
  postId    BigInt?   @map("post_id")
  commentId BigInt?   @map("comment_id")
  chatThreadId BigInt? @map("chat_thread_id")
  type      String    @db.VarChar(50)
  content   String?   @db.VarChar(255)
  isRead    Boolean   @default(false) @map("is_read")
  createdAt DateTime  @default(now()) @map("created_at")
  
  user      User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  post      Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  chatThread ChatThread? @relation(fields: [chatThreadId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([chatThreadId])
  @@index([commentId])
  @@index([postId])
  @@index([userId])
  @@map("notifications")
  @@schema("public")
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @db.VarChar(255)
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model LogMember {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @unique @map("user_id")
  displayName String?   @map("display_name") @db.VarChar(100)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(512)
  bio         String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
  @@schema("horok_log")
}

model CodingMember {
  id          BigInt                  @id @default(autoincrement())
  userId      BigInt                  @unique @map("user_id")
  nickname    String?                 @db.VarChar(50)
  avatarUrl   String?                 @map("avatar_url") @db.VarChar(512)
  tier        String?                 @db.VarChar(30)
  rating      Int                     @default(0)
  solvedCount Int                     @default(0) @map("solved_count")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @default(now()) @updatedAt @map("updated_at")

  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
  @@schema("horok_coding")
}

model CodingProblem {
  id                BigInt   @id @default(autoincrement())
  number            Int      @unique
  slug              String   @unique @db.VarChar(120)
  title             String   @db.VarChar(200)
  level             String   @db.VarChar(20)
  category          String   @db.VarChar(50)
  duration          String   @db.VarChar(30)
  acceptanceRate    String   @map("acceptance_rate") @db.VarChar(20)
  summary           String   @db.Text
  prompt            String   @db.Text
  examples          Json
  testCases         Json     @map("test_cases")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([level, number], map: "idx_coding_problems_level_number")
  @@map("problems")
  @@schema("horok_coding")
}

model CodingProblemProgress {
  id              BigInt                  @id @default(autoincrement())
  userId          BigInt                  @map("user_id")
  problemSlug     String                  @map("problem_slug") @db.VarChar(120)
  problemNumber   Int?                    @map("problem_number")
  status          String                  @default("not_started") @db.VarChar(20)
  lastLanguage    String?                 @map("last_language") @db.VarChar(20)
  lastCode        String?                 @map("last_code") @db.Text
  lastSubmittedAt DateTime?               @map("last_submitted_at")
  solvedAt        DateTime?               @map("solved_at")
  solvedDurationSeconds Int?              @map("solved_duration_seconds")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @default(now()) @updatedAt @map("updated_at")

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSlug])
  @@map("problem_progress")
  @@schema("horok_coding")
}

model CodingSubmission {
  id             BigInt                  @id @default(autoincrement())
  userId         BigInt                  @map("user_id")
  problemSlug    String                  @map("problem_slug") @db.VarChar(120)
  problemNumber  Int?                    @map("problem_number")
  language       String                  @db.VarChar(20)
  sourceCode     String                  @map("source_code") @db.Text
  output         String?                 @db.Text
  expectedOutput String?                 @map("expected_output") @db.Text
  status         String                  @db.VarChar(20)
  elapsedSeconds Int?                    @map("elapsed_seconds")
  createdAt      DateTime                @default(now()) @map("created_at")

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("submissions")
  @@schema("horok_coding")
}

model CodingSavedCode {
  id            BigInt                  @id @default(autoincrement())
  userId        BigInt                  @map("user_id")
  problemSlug   String                  @map("problem_slug") @db.VarChar(120)
  problemNumber Int?                    @map("problem_number")
  language      String                  @db.VarChar(20)
  sourceCode    String                  @map("source_code") @db.Text
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @default(now()) @updatedAt @map("updated_at")

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSlug, language])
  @@map("saved_codes")
  @@schema("horok_coding")
}
